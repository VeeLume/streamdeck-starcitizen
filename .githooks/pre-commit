#!/usr/bin/env bash
set -euo pipefail

echo "▶ cargo fmt (auto-fix)"

# Remember which files are currently staged (excluding deleted files)
STAGED=$(git diff --cached --name-only --diff-filter=d)

cargo fmt --all

# Re-stage only the files that were already staged (picks up fmt changes)
if [ -n "$STAGED" ]; then
    echo "$STAGED" | xargs git add
fi
