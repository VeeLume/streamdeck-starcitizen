{
    "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
    "UUID": "icu.veelume.starcitizen",
    "Name": "starcitizen",
    "CodePath": "bin/icu.veelume.starcitizen.exe",
    "Author": "Veelume",
    "Version": "0.1.0.0",
    "Description": "Stream Deck plugin for starcitizen",
    "Icon": "images/plugin",
    "OS": [
        {
            "Platform": "windows",
            "MinimumVersion": "10"
        }
    ],
    "SDKVersion": 3,
    "Software": {
        "MinimumVersion": "7.1"
    },
    "Category": "starcitizen",
    "CategoryIcon": "images/category",
    "Actions": [
        {
            "UUID": "icu.veelume.starcitizen.example",
            "Name": "Example Action",
            "Icon": "images/example",
            "Tooltip": "An example action",
            "PropertyInspectorPath": "pi/example.html",
            "Controllers": [
                "Keypad"
            ],
            "States": [
                {
                    "Image": "images/example",
                    "TitleAlignment": "middle",
                    "FontSize": 12,
                    "FontFamily": "Arial"
                }
            ]
        }
    ]
}
